	<DoCommands>
		<!-- The name of a DoCommand is case sensitive and is referenced by plug-ins and internally by xShunter itself, so the name must be correctly set here. -->
		<DoCommand Name="CmdExample"> <!-- example_cmd.cpp (It is good practice to note the name of the OpenTTD source code file containing information about this DoCommand here for reference.) -->
			<!-- The list of parameters belonging to the DoCommand. This is the parameters OpenTTD sends via Admin Interface when sending log information about this DoCommand being executed.
			     The following is a list of all parameter types that exist with information about the binary format on the network packet in the name (normally names should be short and not contain any spaces).
			     This is not only cosmetic/informational, it defines how a parameter is parsed from the network packet, i.e. how many bytes are parsed for this parameter before the next parameter is expected. A wrong type can mess up the parsing for the whole DoCommand. -->
			<Params>
				<Param Name="Example bool" Type="boolean" /> <!-- Boolean value ("bool" is an alias for this), 1 byte is parsed from the network packet for this data type. -->
				<Param Name="Example sbyte" Type="int8" /> <!-- Signed byte integer ("sbyte" is an alias for this), 1 byte is parsed from the network packet for this data type. -->
				<Param Name="Example byte" Type="uint8" /> <!-- Unsigned byte integer ("byte" is an alias for this), 1 byte is parsed from the network packet for this data type. -->
				<Param Name="Example short" Type="int16" /> <!-- Signed short integer ("short" is an alias for this), 2 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example ushort" Type="uint16" /> <!-- Unsigned short integer ("ushort" is an alias for this), 2 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example int" Type="int32" /> <!-- Signed integer ("int" is an alias for this), 4 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example uint" Type="uint32" /> <!-- Unsigned integer ("uint" is an alias for this), 4 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example long" Type="int64" /> <!-- Signed long integer ("long" is an alias for this), 8 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example ulong" Type="uint64" /> <!-- Unsigned long integer ("ulong" is an alias for this), 8 bytes are parsed from the network packet for this data type. -->
				<Param Name="Example string" Type="string" /> <!-- For strings all bytes are parsed until the end of the text is signaled by a zero byte character. -->
				<!-- <Param Name="" Type="" /> -->
				<!-- Version: v2.230503 --> 
			</Params>
		</DoCommand>
